local function getNpcModels()
	local npcs = {}
	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("Model") and obj:FindFirstChild("Humanoid") and obj:FindFirstChild("HumanoidRootPart") then
			if Players:GetPlayerFromCharacter(obj) == nil then
				table.insert(npcs, obj)
			end
		end
	end
	return npcs
end

local function restoreAllHitboxes()
	for hrp, data in pairs(originalSizes) do
		if hrp and hrp.Parent then
			hrp.Size = data.Size
			hrp.Transparency = data.Transparency
			hrp.Color = data.Color
			hrp.CanCollide = data.CanCollide
			hrp.Massless = data.Massless
		end
	end
	originalSizes = {}
end

-- FIXED CLEANUP: Completely safe and aggressive
local function cleanupESP()
	for model, data in pairs(espObjects) do
		pcall(function() if data.Highlight then data.Highlight:Destroy() end end)
		pcall(function() if data.Box and data.Box.Remove then data.Box:Remove() end end)
		pcall(function() if data.Tracer and data.Tracer.Remove then data.Tracer:Remove() end end)
		pcall(function() if data.Name and data.Name.Remove then data.Name:Remove() end end)
	end
	espObjects = {}
	if fovCircle then
		pcall(function() fovCircle:Remove() end)
		fovCircle = nil
	end
end

local function isValidTarget(model, isPlayerChar, useTeamCheck)
	if not model or not model.Parent then return false end
	local hrp = model:FindFirstChild("HumanoidRootPart")
	local head = model:FindFirstChild("Head")
	local humanoid = model:FindFirstChild("Humanoid")
	if not hrp or not head or not humanoid then return false end
	if humanoid.Health <= 0 then return false end

	if isPlayerChar and useTeamCheck then
		local player = Players:GetPlayerFromCharacter(model)
		if not player then return false end
		return player.Team ~= LocalPlayer.Team or player.Team == nil
	end
	return true
end

local function createESP(model, isPlayerChar)
	if espObjects[model] then return end

	local highlight = Instance.new("Highlight")
	highlight.OutlineColor = Color3.fromRGB(255, 100, 100)
	highlight.FillTransparency = 0.5
	highlight.OutlineTransparency = 0
	highlight.Parent = model

	local fillColor = Color3.fromRGB(255, 50, 50)
	if isPlayerChar then
		local player = Players:GetPlayerFromCharacter(model)
		if player and player.TeamColor then fillColor = player.TeamColor.Color end
	end
	highlight.FillColor = fillColor

	local box = Drawing.new("Square")
	box.Thickness = 2; box.Color = Color3.fromRGB(255, 50, 50); box.Filled = false; box.Transparency = 1

	local tracer = Drawing.new("Line")
	tracer.Thickness = 2; tracer.Color = Color3.fromRGB(255, 80, 80); tracer.Transparency = 1

	local nameLabel = Drawing.new("Text")
	nameLabel.Size = 14; nameLabel.Center = true; nameLabel.Outline = true; nameLabel.Color = Color3.fromRGB(255, 255, 255); nameLabel.Transparency = 1

	espObjects[model] = {Highlight = highlight, Box = box, Tracer = tracer, Name = nameLabel}
end

local function updateESP()
	if not espEnabled then return end

	-- Create ESP
	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= LocalPlayer and player.Character then
			if isValidTarget(player.Character, true, espTeamCheck) then
				if not espObjects[player.Character] then
					createESP(player.Character, true)
				end
			end
		end
	end

	if espNpc then
		for _, obj in ipairs(getNpcModels()) do
			if isValidTarget(obj, false, false) then
				if not espObjects[obj] then
					createESP(obj, false)
				end
			end
		end
	end

	-- Update ESP - REMOVED onScreen restriction when Off Screen ESP is enabled
	for model, data in pairs(espObjects) do
		local isPlayerChar = Players:GetPlayerFromCharacter(model) ~= nil
		if isValidTarget(model, isPlayerChar, isPlayerChar and espTeamCheck or false) then
			local root = model:FindFirstChild("HumanoidRootPart")
			local head = model:FindFirstChild("Head")

			local headPos = Camera:WorldToViewportPoint(head.Position)
			local rootPos = Camera:WorldToViewportPoint(root.Position)
			local legPos = Camera:WorldToViewportPoint(root.Position - Vector3.new(0, 3.5, 0))

			local boxHeight = (legPos.Y - headPos.Y) * 1.1
			local boxWidth = boxHeight * 0.55

			-- When Off Screen ESP is ON → ALWAYS draw everything (even behind walls)
			if offScreenEspEnabled or headPos.Z > 0 then
				if boxEnabled then
					data.Box.Visible = true
					data.Box.Position = Vector2.new(headPos.X - boxWidth / 2, headPos.Y)
					data.Box.Size = Vector2.new(boxWidth, boxHeight)
				else
					data.Box.Visible = false
				end

				if nameEnabled then
					data.Name.Visible = true
					data.Name.Text = model.Name
					data.Name.Position = Vector2.new(headPos.X, headPos.Y - 25)
				else
					data.Name.Visible = false
				end

				if tracerEnabled then
					data.Tracer.Visible = true
					local screenBottom = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
					data.Tracer.From = screenBottom
					data.Tracer.To = Vector2.new(rootPos.X, rootPos.Y)
				else
					data.Tracer.Visible = false
				end

				data.Highlight.Enabled = highlightEnabled
			else
				data.Box.Visible = false
				data.Tracer.Visible = false
				data.Name.Visible = false
				data.Highlight.Enabled = false
			end
		else
			-- Aggressive cleanup
			pcall(function() if data.Highlight then data.Highlight:Destroy() end end)
			pcall(function() if data.Box and data.Box.Remove then data.Box:Remove() end end)
			pcall(function() if data.Tracer and data.Tracer.Remove then data.Tracer:Remove() end end)
			pcall(function() if data.Name and data.Name.Remove then data.Name:Remove() end end)
			espObjects[model] = nil
		end
	end
end

local function getClosestTarget()
	local closest = nil
	local closestDist = math.huge
	local mousePos = UserInputService:GetMouseLocation()
	local localHRP = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")

	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= LocalPlayer and player.Character then
			if not aimbotTeamCheck or not (player.Team and LocalPlayer.Team and player.Team == LocalPlayer.Team) then
				local char = player.Character
				local targetPart = char:FindFirstChild(aimPart) or char:FindFirstChild("Head")
				if targetPart then
					local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
					if onScreen then
						local distToCrosshair = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
						local finalDist = distToCrosshair
						if aimType == "Player" and localHRP then finalDist = (localHRP.Position - targetPart.Position).Magnitude end
						if aimType == "Health" then
							local hum = char:FindFirstChild("Humanoid")
							finalDist = hum and hum.Health or 9999
						end

						if finalDist < closestDist and distToCrosshair < fovRadius then
							local origin = Camera.CFrame.Position
							local direction = (targetPart.Position - origin)
							local rayParams = RaycastParams.new()
							rayParams.FilterDescendantsInstances = {LocalPlayer.Character}
							rayParams.FilterType = Enum.RaycastFilterType.Exclude
							local result = workspace:Raycast(origin, direction, rayParams)
							if not wallCheckEnabled or (not result or result.Instance:IsDescendantOf(char)) then
								closest = targetPart
								closestDist = finalDist
							end
						end
					end
				end
			end
		end
	end

	if aimbotNpc then
		for _, obj in ipairs(getNpcModels()) do
			local targetPart = obj:FindFirstChild(aimPart) or obj:FindFirstChild("Head")
			if targetPart then
				local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
				if onScreen then
					local distToCrosshair = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
					local finalDist = distToCrosshair
					if aimType == "Player" and localHRP then finalDist = (localHRP.Position - targetPart.Position).Magnitude end
					if aimType == "Health" then
						local hum = obj:FindFirstChild("Humanoid")
						finalDist = hum and hum.Health or 9999
					end

					if finalDist < closestDist and distToCrosshair < fovRadius then
						local origin = Camera.CFrame.Position
						local direction = (targetPart.Position - origin)
						local rayParams = RaycastParams.new()
						rayParams.FilterDescendantsInstances = {LocalPlayer.Character}
						rayParams.FilterType = Enum.RaycastFilterType.Exclude
						local result = workspace:Raycast(origin, direction, rayParams)
						if not wallCheckEnabled or (not result or result.Instance:IsDescendantOf(obj)) then
							closest = targetPart
							closestDist = finalDist
						end
					end
				end
			end
		end
	end

	return closest
end

local function updateHitboxes()
	if not hitboxEnabled then return end

	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= LocalPlayer and player.Character then
			if isValidTarget(player.Character, true, hitboxTeamCheck) then
				local part = player.Character:FindFirstChild(hitboxPart)
				if part and part:IsA("BasePart") then
					if not originalSizes[part] then
						originalSizes[part] = {Size = part.Size, Transparency = part.Transparency, Color = part.Color, CanCollide = part.CanCollide, Massless = part.Massless}
					end
					part.Size = Vector3.new(hitboxSize, hitboxSize, hitboxSize)
					part.Transparency = 0.4
					part.Color = Color3.fromRGB(200, 0, 0)
					part.CanCollide = false
					part.Massless = true
				end
			end
		end
	end

	if hitboxNpc then
		for _, obj in ipairs(getNpcModels()) do
			local part = obj:FindFirstChild(hitboxPart)
			if part and part:IsA("BasePart") then
				if not originalSizes[part] then
					originalSizes[part] = {Size = part.Size, Transparency = part.Transparency, Color = part.Color, CanCollide = part.CanCollide, Massless = part.Massless}
				end
				part.Size = Vector3.new(hitboxSize, hitboxSize, hitboxSize)
				part.Transparency = 0.4
				part.Color = Color3.fromRGB(200, 0, 0)
				part.CanCollide = false
				part.Massless = true
			end
		end
	end
end

local function onRenderStepped()
	updateESP()

	if showFovCircle then
		if not fovCircle then
			fovCircle = Drawing.new("Circle")
			fovCircle.Color = Color3.fromRGB(255, 50, 50)
			fovCircle.Thickness = 2
			fovCircle.Transparency = 0.7
			fovCircle.Filled = false
		end
		fovCircle.Radius = fovRadius
		fovCircle.Position = UserInputService:GetMouseLocation()
		fovCircle.Visible = true
	elseif fovCircle then
		fovCircle.Visible = false
	end

	if aimbotEnabled and isHoldingRMB then
		local targetPart = getClosestTarget()
		if targetPart then
			local targetPos = targetPart.Position
			local currentCFrame = Camera.CFrame
			local targetCFrame = CFrame.lookAt(currentCFrame.Position, targetPos)
			if smoothness <= 0 then
				Camera.CFrame = targetCFrame
			else
				Camera.CFrame = currentCFrame:Lerp(targetCFrame, smoothness)
			end
		end
	end
end

local function onInputBegan(input, gameProcessed)
	if gameProcessed then return end
	if input.UserInputType == Enum.UserInputType.MouseButton2 then
		isHoldingRMB = true
	end
end

local function onInputEnded(input)
	if input.UserInputType == Enum.UserInputType.MouseButton2 then
		isHoldingRMB = false
	end
end

