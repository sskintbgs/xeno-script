-- Cache
local characterCache = {}

local function getValue(obj)
    if not obj then return "" end
    if obj:IsA("TextLabel") or obj:IsA("TextButton") then
        return obj.Text:gsub("^%s+", ""):gsub("%s+$", "")
    end
    return tostring(obj.Value or obj.Text or "")
end

local function parseMoneyPerSec(text)
    if not text or text == "" then return 0 end
    text = text:upper():gsub("%$", ""):gsub("/S", ""):gsub(",", ""):gsub(" ", "")
    local num = tonumber(text)
    if num then return num end
    local numPart, suffix = text:match("([%d%.]+)([KMBT]?)")
    if numPart then
        local value = tonumber(numPart) or 0
        if suffix == "K" then return value * 1000 end
        if suffix == "M" then return value * 1000000 end
        if suffix == "B" then return value * 1000000000 end
        if suffix == "T" then return value * 1000000000000 end
        return value
    end
    return 0
end

local function cacheCharacter(model)
    local brain = model:FindFirstChild("BrainrotInfo")
    if not brain or not brain:FindFirstChild("Content") then
        characterCache[model] = { rarityLower = "", variantLower = "", mps = 0 }
        return
    end

    local content = brain.Content
    local rawRarity = getValue(content:FindFirstChild("Rarity"))
    local rawVariant = getValue(content:FindFirstChild("Variant"))

    characterCache[model] = {
        rarityLower = rawRarity:lower(),
        variantLower = rawVariant:lower(),
        mps = parseMoneyPerSec(getValue(content:FindFirstChild("MoneyPerSec")))
    }
end

-- Initial cache
for _, model in ipairs(AvailableCharacters:GetChildren()) do
    cacheCharacter(model)
end

-- Filter
local function shouldCarry(model)
    if not carryEnabled then return false end

    local data = characterCache[model]
    if not data then return true end

    local rarityOK = (#selectedRaritiesLower == 0)
    if not rarityOK then
        for _, sel in ipairs(selectedRaritiesLower) do
            if sel == "none" then
                if data.rarityLower == "" or data.rarityLower == "none" then
                    rarityOK = true
                    break
                end
            elseif sel == data.rarityLower then
                rarityOK = true
                break
            end
        end
    end

    local variantOK = (#selectedVariantsLower == 0)
    if not variantOK then
        for _, sel in ipairs(selectedVariantsLower) do
            if sel == "none" then
                if data.variantLower == "" or data.variantLower == "none" then
                    variantOK = true
                    break
                end
            elseif sel == data.variantLower then
                variantOK = true
                break
            end
        end
    end

    local mpsOK = data.mps >= minMoneyPerSec

    return rarityOK and variantOK and mpsOK
end

local function fireProximityPrompt(model)
    local prompt = model:FindFirstChild("ProximityPrompt") or model:FindFirstChildWhichIsA("ProximityPrompt", true)
    if not prompt then return end
    if fireproximityprompt then
        fireproximityprompt(prompt)
    else
        local old = prompt.HoldDuration
        prompt.HoldDuration = 0
        prompt:InputHoldBegin()
        prompt:InputHoldEnd()
        prompt.HoldDuration = old
    end
end

local function processModel(model)
    if not shouldCarry(model) then return end
    task.defer(function()
        fireProximityPrompt(model)
        if postPromptDelay > 0 then task.wait(postPromptDelay) end
        GamestateEvent:FireServer("FinishCarry")
    end)
end

-- 0.1s scanner
local function startScanner()
    task.spawn(function()
        while true do
            if carryEnabled then
                for _, model in ipairs(AvailableCharacters:GetChildren()) do
                    cacheCharacter(model)
                    processModel(model)
                end
            end
            task.wait(scanInterval)
        end
    end)
end

startScanner()

local function smartRefresh()
    if not carryEnabled then return end
    for _, model in ipairs(AvailableCharacters:GetChildren()) do
        cacheCharacter(model)
        processModel(model)
    end
end

-- Child added
AvailableCharacters.ChildAdded:Connect(function(model)
